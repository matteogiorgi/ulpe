#!/usr/bin/env sh

# This script is intended to be used on a Debian or Debian-based distribution
# and installs a minimal UNIX work environment with some useful packages.




### Functions
#############

sudo_privileges() {
    id -Gn 2>/dev/null | grep -qw "sudo"
}
# ---
ask_user() {
    printf "%s\n" "$1"
    ANS=
    printf "%s" "wish to proceed anyway? [y/N] "
    read -r ANS
    case "$ANS" in
        y | Y | yes | YES) printf "\n%s\n" "setup resumed";;
        *) printf "\n%s\n" "setup interrupted"; exit 1;;
    esac
}
# ---
has_testing() {
    grep -E \
        '^[[:space:]]*deb[[:space:]]+https?://deb\.debian\.org/debian[[:space:]]+(testing|unstable)([[:space:]]|$)' \
        /etc/apt/sources.list \
        >/dev/null 2>&1
}
# ---
testing_setup() {
    [ -s /etc/apt/sources.list ] && grep '^[^#]' /etc/apt/sources.list >/dev/null || return
    REPO="deb https://deb.debian.org/debian testing main contrib non-free non-free-firmware"
    if ! has_testing; then
        sudo cp /etc/apt/sources.list /etc/apt/sources.list.ulpe.bak 2>/dev/null || true
        printf "%s\n" "$REPO" \
            | sudo tee -a /etc/apt/sources.list >/dev/null \
            && sudo cp "$SCRIPTPATH/base/preferences" "/etc/apt/" >/dev/null 2>&1
    fi
    sudo awk '
    /^[[:space:]]*deb[[:space:]].*(testing|unstable)/ {
        line = $0
        if (line !~ /[[:space:]]contrib([[:space:]]|$)/)
            line = line " contrib"
        if (line !~ /[[:space:]]non-free([[:space:]]|$)/)
            line = line " non-free"
        if (line !~ /[[:space:]]non-free-firmware([[:space:]]|$)/)
            line = line " non-free-firmware"
        print line
        next
    }
    { print }
    ' /etc/apt/sources.list | sudo tee /etc/apt/sources.list.ulpe.tmp >/dev/null \
      && sudo mv /etc/apt/sources.list.ulpe.tmp /etc/apt/sources.list
}
# ---
try_run() {
    if "$@" >/dev/null 2>&1; then
        printf "\n"
    else
        printf ": %s\n" "command failed"
    fi
}
# ---
store_conf() {
    backup_conf() {
        [ -e "$1" ] || [ -L "$1" ] || return
        printf "%s" "removing '$1'"
        if [ -L "$1" ]; then
            try_run unlink "$1"
        else
            try_run mv "$1" "$2/"
        fi
    }
    # ---
    RESTORE="$HOME/.ulpe_recovery"
    SCRIPT=
    mkdir -p "$RESTORE"
    printf "\n%s\n" "REMOVING BASE SCRIPTS"
    for SCRIPT in \
        .profile \
        .bashrc \
        .bash_logout \
        .vimrc \
        .tmux.conf \
        .local/bin/fetch.sh
    do
        backup_conf "$HOME/$SCRIPT" "$RESTORE"
    done
}




### Checks
##########

if [ "$(id -u)" -eq 0 ]; then
    printf "\n%s"   "This script MUST NOT be run as root since it makes changes to"
    printf "\n%s"   "the \$HOME directory of the \$USER executing it."
    printf "\n%s"   "Run this script as a normal user, you will be asked for a sudo"
    printf "\n%s\n" "password when necessary."
    exit 1
fi
# ---
if [ -d "$HOME/.ulpe_recovery" ]; then
    printf "\n%s"   "WARNING: ULPE already set."
    printf "\n%s\n" "Remove ~/.ulpe_recovery directory and run this script again."
    exit 1
fi




### ULPE-Base
#############

cat << EOF

        __                     __
.--.--.|  |.-----.-----.      |  |--.---.-.-----.-----.
|  |  ||  ||  _  |  -__|      |  _  |  _  |__ --|  -__|
|_____||__||   __|_____| ____ |_____|___._|_____|_____|
           |__|

EOF




### Packages
############

STABLE_PACKAGES="git wget curl dash bash bash-completion shfmt fzy less file fd-find trash-cli xclip \
wl-clipboard procps x11-xkb-utils tmux exuberant-ctags wamerican groff tcc pcc build-essential gdb \
nasm yasm binutils linux-perf strace ltrace pkg-config valgrind indent gcc-doc man-db manpages-dev \
cppman python3-full python3-dev python3-pip pypy3 pypy3-dev pypy3-venv python-is-python3 black"
TESTING_PACKAGES="vim"
ALL_PACKAGES="$STABLE_PACKAGES $TESTING_PACKAGES"
# ---
for PKG in $ALL_PACKAGES; do
    if ! apt-get -s install "$PKG" >/dev/null 2>&1; then
        PROBLEMS="${PROBLEMS:+$PROBLEMS }$PKG"
    fi
done
# ---
if [ -n "${PROBLEMS-}" ]; then
    ask_user "these packages might cause issues: '$PROBLEMS'"
fi
# ---
if ! sudo_privileges; then
    ask_user "'$USER' does not have sudo privileges"
fi




### Dependencies
################

SCRIPTPATH="$( cd "$(dirname "$0")" ; pwd -P )" || exit 1
if sudo_privileges; then
    . /etc/os-release 2>/dev/null || exit 1
    if [ "$ID" = "debian" ]; then
        case ${VERSION_ID:-0} in
            ''|*[!0-9]*) ;;
            *)
                [ "$VERSION_ID" -ge 12 ] && testing_setup
                ;;
        esac
    fi
    # ---
    if has_testing; then
        sudo sh -c '
            STABLE_PACKAGES="$1"
            TESTING_PACKAGES="$2"
            apt-get update &&
            apt-get upgrade -qq -y --allow-downgrades &&
            { apt-get purge -qq -y vim-tiny || true; }
            for PKG in $STABLE_PACKAGES; do
                apt-get install -y -qq --no-install-recommends "$PKG" || true
            done
            for PKG in $TESTING_PACKAGES; do
                apt-get install -y -qq --no-install-recommends -t testing "$PKG" || true
            done
            apt-get -qq -y autoremove --purge &&
            apt-get -qq -y autoclean
        ' _ "$STABLE_PACKAGES" "$TESTING_PACKAGES" || {
            printf "\n%s\n" "packages installation failed"
            exit 1
        }
    else
        sudo sh -c '
            apt-get update &&
            apt-get upgrade -qq -y --allow-downgrades &&
            { apt-get purge -qq -y vim-tiny || true; }
            for PKG in "$@"; do
                apt-get install -y -qq --no-install-recommends "$PKG" || true
            done
            apt-get -qq -y autoremove --purge &&
            apt-get -qq -y autoclean
        ' _ $ALL_PACKAGES || {
            printf "\n%s\n" "packages installation failed"
            exit 1
        }
    fi
fi




### Start
#########

store_conf
printf "\n%s\n" "COPYING BASE SCRIPTS"
for SCRIPT in \
    .profile \
    .bashrc \
    .bash_logout \
    .vimrc \
    .tmux.conf \
    fetch.sh
do
    printf "%s" "copying '$SCRIPT'"
    case $SCRIPT in
        fetch.sh)
            mkdir -p "$HOME/.local/bin/" >/dev/null 2>&1 || continue
            try_run cp "$SCRIPTPATH/base/$SCRIPT" "$HOME/.local/bin/"
            ;;
        *)
            try_run cp "$SCRIPTPATH/base/$SCRIPT" "$HOME/"
            ;;
    esac
done
# ---
if sudo_privileges; then
    sudo chsh -s "$(command -v bash)" "$USER"
fi




### Finish
##########

printf "\n%s\n" "BASE SETUP COMPLETE."
