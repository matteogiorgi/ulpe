#!/usr/bin/env sh

# This script is intended to be used on a Debian or Debian-based distribution
# and installs few useful Vim plugins for a better coding experience.




### Functions
#############

sudo_privileges() {
    id -Gn 2>/dev/null | grep -qw "sudo"
}
# ---
ask_user() {
    printf "%s\n" "$1"
    ANS=
    printf "%s" "wish to proceed anyway? [y/N] "
    read -r ANS
    case "$ANS" in
        y | Y | yes | YES) printf "\n%s\n" "setup resumed";;
        *) printf "\n%s\n" "setup interrupted"; exit 1;;
    esac
}




### Checks
##########

if [ "$(id -u)" -eq 0 ]; then
    printf "\n%s"   "This script MUST NOT be run as root since it makes changes to"
    printf "\n%s"   "the \$HOME directory of the \$USER executing it."
    printf "\n%s"   "Run this script as a normal user, you will be asked for a sudo"
    printf "\n%s\n" "password when necessary."
    exit 1
fi
# ---
if ! command -v \git >/dev/null 2>&1; then
    printf "\n%s"   "WARNING. Git not found: install Git and run this script"
    printf "\n%s\n" "═══════  again."
    exit 1
fi
# ---
case "$(\vim --version 2>/dev/null | head -n1)" in
    *"Vi IMproved 9"*) ;;
    *)
        printf "\n%s"   "WARNING. Vim9 not found: install Vim9 and run this script"
        printf "\n%s\n" "═══════  again."
        exit 1
        ;;
esac




### ULPE-Plug
#############

cat << EOF

        __                            __
.--.--.|  |.-----.-----.      .-----.|  |.--.--.-----.
|  |  ||  ||  _  |  -__|      |  _  ||  ||  |  |  _  |
|_____||__||   __|_____| ____ |   __||__||_____|___  |
           |__|               |__|             |_____|

EOF




### Dependencies
################

if ! sudo_privileges; then
    ask_user "'$USER' does not have sudo privileges"
fi
# ---
if sudo_privileges; then
    sudo sh -c '
        apt-get update &&
        apt-get -qq -y autoremove --purge &&
        apt-get -qq -y autoclean
    ' || {
        printf "\n%s\n" "packages maintenance failed"
        exit 1
    }
fi




### Start
#########

set -- \
    "https://github.com/ctrlpvim/ctrlp.vim.git" \
    "https://github.com/machakann/vim-sandwich.git" \
    "https://github.com/tpope/vim-commentary.git" \
    "https://github.com/cohama/lexima.vim.git" \
    "https://github.com/wellle/context.vim.git"
# ---
VIM=$HOME/.vim
START="$VIM/pack/plug/start"
mkdir -p "$START" >/dev/null 2>&1 || {
    printf "\n%s\n" "makedir '$START' failed"
    exit 1
}
# ---
for DIR in "$START"/*; do
    [ -e "$DIR" ] && [ -d "$DIR/.git" ] || continue
    ORIGIN=$(\git -C "$DIR" config --get remote.origin.url 2>/dev/null)
    printf "\n%s\n" "UPDATING $(basename "$DIR")"
    \git -C "$DIR" pull --ff-only
    for URL in "$@"; do
        if [ "$ORIGIN" = "$URL" ]; then
            case " ${FOUND-} " in
                *" $URL "*) :;;
                *) FOUND="${FOUND:+$FOUND }$URL";;
            esac
        fi
    done
done
# ---
for URL in "$@"; do
    case " ${FOUND-} " in
        *" $URL "*)
            { :; }
            ;;
        *)
            printf "\n%s\n" "CLONING $URL"
            \git -C "$START" clone "$URL"
            ;;
    esac
done
# ---
SCRIPTPATH="$( cd "$(dirname "$0")" ; pwd -P )" || exit 1
if [ ! -d "$VIM/plugin" ] && [ -d "$SCRIPTPATH/plug" ]; then
    cp -R "$SCRIPTPATH/plug" "$VIM/plugin"
fi




### Finish
##########

printf "\n%s\n" "PLUG SETUP COMPLETE."
